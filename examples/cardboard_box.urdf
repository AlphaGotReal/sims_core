<robot name="cardboard_box">
  <link name="base">
    <inertial><mass value="0.3"/><inertia ixx="1e-3" ixy="0" ixz="0" iyy="1e-3" iyz="0" izz="1e-3"/></inertial>
    <collision><geometry><box size="0.3 0.2 0.003"/></geometry><origin xyz="0 0 -0.0985" rpy="0 0 0"/></collision>
